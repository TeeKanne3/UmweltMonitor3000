<Window x:Class="UmweltMonitor3000.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UmweltMonitor3000"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="UmweltMonitor3000" Height="700" Width="1100"
        Background="#121212">
    <Grid>
        <TabControl TabStripPlacement="Left"
                    
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                     materialDesign:NavigationRailAssist.ShowSelectionBackground="True">
                        
            <TabItem Height="70"
                     >
                <TabItem.Header>
                    <StackPanel Orientation="Vertical">
                        <materialDesign:PackIcon Kind="Connection"
                                                 HorizontalAlignment="Center"
                                                 Height="24"
                                                 Width="24"
                                                 Foreground="White"/>
                        <TextBlock Text="Broker Verbindung"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </TabItem.Header>
                <materialDesign:Card Background="#1E1E1E"
                                     Margin="10"
                                     materialDesign:ElevationAssist.Elevation="Dp5">
                    
                </materialDesign:Card>
            </TabItem>
            
            <TabItem Height="70">
                <TabItem.Header>
                    <StackPanel Orientation="Vertical">
                        <materialDesign:PackIcon Kind="ChartArc"
                                    HorizontalAlignment="Center"
                                    Height="24"
                                    Width="24"
                                    Foreground="White"/>
                        <TextBlock Text="Statistiken"
                      FontSize="15"
                      FontWeight="Bold"
                      Foreground="White"/>
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
            
            <TabItem Height="70">
                <TabItem.Header>
                    <StackPanel Orientation="Vertical">
                        <materialDesign:PackIcon Kind="Connection"
                                    HorizontalAlignment="Center"
                                    Height="24"
                                    Width="24"
                                    Foreground="White"/>
                        <TextBlock Text="Platzhalter"
                      FontSize="15"
                      FontWeight="Bold"
                      Foreground="White"/>
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
