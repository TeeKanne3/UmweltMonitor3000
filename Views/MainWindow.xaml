<Window x:Class="UmweltMonitor3000.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UmweltMonitor3000"
        xmlns:Models="clr-namespace:UmweltMonitor3000.Application.Models"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="UmweltMonitor3000"
        WindowStyle="SingleBorderWindow"
        Height="700"
        MaxHeight="700"
        Width="1100"
        MaxWidth="1100"
        Icon="/Assets/Icon/AppIcon.ico">
    <Grid>
        <TabControl TabStripPlacement="Left"
                    Background="#1a2035"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    materialDesign:ColorZoneAssist.Mode="Standard"
                    materialDesign:NavigationRailAssist.ShowSelectionBackground="True">
            <materialDesign:NavigationRailAssist.FloatingContent>
                <Image Source="/Assets/Icon/FloatingContent.ico"
                       Height="32"
                       Width="32"
                       Margin="0,10,0,10" />
            </materialDesign:NavigationRailAssist.FloatingContent>
            <TabItem Height="50"
                     Width="200">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="Connection"
                                                 Height="24"
                                                 Width="24"
                                                 Margin="-40,0,0,0"
                                                 Foreground="White" />

                        <TextBlock Text="Verbindung"
                                   FontSize="14"
                                   FontFamily="Inter"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Grid.Column="1"
                                   Foreground="White" />
                    </Grid>

                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="MQTT-Dashboard"
                               FontFamily="Inter"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               FontWeight="SemiBold" />

                    <materialDesign:Card Background="#181d29"
                                         materialDesign:ElevationAssist.Elevation="Dp3"
                                         Margin="10,0,10,10"
                                         Grid.Row="1"
                                         UniformCornerRadius="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="70" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>



                            <TextBlock Text="Verbinden"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15" />

                            <StackPanel Orientation="Horizontal"
                                        Grid.Row="1">
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="50"
                                         Width="270"
                                         materialDesign:HintAssist.Hint="IP-Adresse"
                                         materialDesign:HintAssist.Background="#212121"
                                         materialDesign:HintAssist.HintPaddingBrush="Transparent"
                                         HorizontalAlignment="Left"
                                         Margin="10,0,0,0" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="50"
                                         Width="60"
                                         materialDesign:HintAssist.Hint="Port"
                                         materialDesign:HintAssist.Background="#212121"
                                         materialDesign:HintAssist.HintPaddingBrush="Transparent"
                                         HorizontalAlignment="Left"
                                         Margin="10,0,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="10,0,0,0">
                                <materialDesign:PackIcon Kind="ConnectWithoutContact"
                                                         Height="24"
                                                         Width="24"
                                                         Margin="0,35,5,0" />

                                <Button Content="Verbindung herstellen!"
                                        Style="{StaticResource MaterialDesignFlatButton}" />
                            </StackPanel>



                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="10,0,0,0">
                                <materialDesign:PackIcon Kind="LocalAreaNetworkDisconnect"
                                                         Height="24"
                                                         Width="24"
                                                         Margin="0,35,5,0" />

                                <Button Content="Verbindung trennen!"
                                        Style="{StaticResource MaterialDesignFlatButton}" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Background="#181d29"
                                         Margin="0,0,10,10"
                                         UniformCornerRadius="20"
                                         Grid.Column="1"
                                         materialDesign:ElevationAssist.Elevation="Dp3"
                                         Grid.Row="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="MQTT Verbindungsstatus"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15" />

                            <TextBlock Text="Status:"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15"
                                       Grid.Row="1" />

                            <TextBlock Text="Up-Time:"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15"
                                       Grid.Row="2" />

                            <TextBlock Text="Broker:"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15"
                                       Grid.Row="3" />
                            <TextBlock Text="Empfangene Nachrichten:"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15"
                                       Grid.Row="4" />

                            <TextBlock Text="Fehler:"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15"
                                       Grid.Row="5" />
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Background="#181d29"
                                         Margin="10,0,10,10"
                                         materialDesign:ElevationAssist.Elevation="Dp3"
                                         Grid.Row="2"
                                         UniformCornerRadius="20"
                                         Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Logs"
                                       FontWeight="SemiBold"
                                       FontFamily="Inter"
                                       Margin="10,10,0,0"
                                       FontSize="15" />
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      Background="#141923"
                                      Margin="10,0,10,10">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeitstempel" />
                                    <DataGridTextColumn Header="Log-Typ" />
                                    <DataGridTextColumn Header="Richtung" />
                                    <DataGridTextColumn Header="Topic" />
                                    <DataGridTextColumn Header="Text" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <TabItem Height="50"
                     Width="200">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="Tree"
                                                 Height="24"
                                                 Width="24"
                                                 Margin="-40,0,0,0"
                                                 Foreground="White" />

                        <TextBlock Text="Pflanzen"
                                   FontSize="14"
                                   FontFamily="Inter"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"
                                   Grid.Column="1"
                                   Foreground="White" />
                    </Grid>

                </TabItem.Header>
                <materialDesign:Card Background="#181d29"
                                     Margin="10"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <ItemsControl Margin="10"
                                  HorizontalAlignment="Stretch">
                        
                        <materialDesign:Card Height="250"
                                             Width="250">

                        </materialDesign:Card>
                        <materialDesign:Card Height="250"
                                             Width="250">

                        </materialDesign:Card>
                        <materialDesign:Card Height="250"
                                             Width="250">

                        </materialDesign:Card>
                        <materialDesign:Card Height="250"
                                             Width="250">

                        </materialDesign:Card>
                    </ItemsControl>

                </materialDesign:Card>

            </TabItem>


            <TabItem Height="50"
                     Width="200">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="ChartAreasplineVariant"
                                                 Height="24"
                                                 Width="24"
                                                 Margin="-40,0,0,0"
                                                 Foreground="White" />

                        <TextBlock Text="Statisitken"
                                   FontSize="14"
                                   FontFamily="Inter"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Grid.Column="1"
                                   Foreground="White" />
                    </Grid>

                </TabItem.Header>

                <materialDesign:Card Background="#181d29"
                                     Margin="10"
                                     materialDesign:ElevationAssist.Elevation="Dp3">

                </materialDesign:Card>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
